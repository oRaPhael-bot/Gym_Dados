table gym_members_exercise_tracking
	lineageTag: 3c6e4ddf-7557-4a51-89b5-8656292380ba

	measure 'BMI Médio' = AVERAGE(gym_members_exercise_tracking[BMIValor])
		lineageTag: ae65e259-2895-4a95-8d23-817ec98b2eb6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Alunos' = COUNTROWS(gym_members_exercise_tracking)
